            "url": {
              "raw": "http://localhost:3000/api/game/bet",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "game", "bet"]
            },
            "description": "执行下注操作（check/call/raise/fold/allin）"
          },
          "response": []
