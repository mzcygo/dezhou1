            "body": {
              "mode": "raw",
              "raw": "{\n  \"roomName\": \"新手练习场\",\n  \"roomType\": \"cash\",\n  \"minBlind\": 10,\n  \"maxBlind\": 100,\n  \"maxPlayers\": 6\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/rooms/create",
              "protocol": "http",
